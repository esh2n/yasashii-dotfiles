# yasashii — Ghostty dark theme
# Calm workspace. Muted teal accent.
# Recommended background: Tokyo Night-inspired deep navy

config-file = themes/yasashii-dark

# Font — Moralerspace for Japanese readability, Nerd Font for icons
font-family = Moralerspace Neon NF
font-family-bold = Moralerspace Neon NF
font-family-italic = Moralerspace Neon NF
font-family-bold-italic = Moralerspace Neon NF
font-size = 15
font-thicken = true
adjust-cell-height = 25%

# Window — generous padding for breathing room
window-padding-x = 24
window-padding-y = 16
window-padding-balance = true
window-padding-color = extend
window-decoration = auto
window-theme = dark
window-save-state = always
window-inherit-working-directory = true
window-inherit-font-size = true

# Background
background-opacity = 0.92
background-blur-radius = 20

# Cursor
cursor-style = bar
cursor-style-blink = true
minimum-contrast = 1.3

# Behavior
shell-integration-features = cursor,title
confirm-close-surface = false
scrollback-limit = 10000
mouse-hide-while-typing = true
clipboard-read = allow
clipboard-write = allow

# macOS
macos-titlebar-style = hidden
macos-option-as-alt = true

# Fix: Shift+Enter in Claude Code
keybind = shift+enter=text:\n

# Minimal keybinds — non-engineers don't need split management
keybind = cmd+t=new_tab
keybind = cmd+w=close_surface
keybind = cmd+c=copy_to_clipboard
keybind = cmd+v=paste_from_clipboard
keybind = cmd+plus=increase_font_size:1
keybind = cmd+equal=increase_font_size:1
keybind = cmd+minus=decrease_font_size:1
keybind = cmd+0=reset_font_size
keybind = cmd+k=clear_screen
keybind = cmd+enter=toggle_fullscreen
