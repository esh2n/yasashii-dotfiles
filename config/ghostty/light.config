# yasashii — Ghostty light theme
# Bright office. Calm blue accent.

config-file = themes/yasashii-light

font-family = Moralerspace Neon NF
font-family-bold = Moralerspace Neon NF
font-family-italic = Moralerspace Neon NF
font-family-bold-italic = Moralerspace Neon NF
font-size = 15
font-thicken = true
adjust-cell-height = 25%

window-padding-x = 24
window-padding-y = 16
window-padding-balance = true
window-padding-color = extend
window-decoration = auto
window-theme = light
window-save-state = always
window-inherit-working-directory = true
window-inherit-font-size = true

background-opacity = 0.95

cursor-style = bar
cursor-style-blink = true
minimum-contrast = 1.3

shell-integration-features = cursor,title
confirm-close-surface = false
scrollback-limit = 10000
mouse-hide-while-typing = true
clipboard-read = allow
clipboard-write = allow

macos-titlebar-style = hidden
macos-option-as-alt = true

keybind = shift+enter=text:\n
keybind = cmd+t=new_tab
keybind = cmd+w=close_surface
keybind = cmd+c=copy_to_clipboard
keybind = cmd+v=paste_from_clipboard
keybind = cmd+plus=increase_font_size:1
keybind = cmd+equal=increase_font_size:1
keybind = cmd+minus=decrease_font_size:1
keybind = cmd+0=reset_font_size
keybind = cmd+k=clear_screen
keybind = cmd+enter=toggle_fullscreen
